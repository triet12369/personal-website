{
  "name": "personal-website",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "cloudflare-worker",
    "demos/*"
  ],
  "engines": {
    "node": ">=24.x"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names \"next,worker\" --prefix-colors \"cyan,yellow\" \"next dev --webpack\" \"npm run dev --workspace=personal-site-worker\"",
    "build": "next build --webpack",
    "build:demos": "npm run build --workspaces --if-present && node scripts/copy-demos.js",
    "test": "vitest run",
    "start": "next start",
    "generate:nebula": "node scripts/generate-nebula.mjs",
    "lint": "eslint --fix 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@mantine/core": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.183.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "gifuct-js": "^2.1.2",
    "gray-matter": "^4.0.3",
    "i18next": "^23.16.8",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "next": "^16.2.1",
    "next-mdx-remote": "^6.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^14.1.3",
    "react-icons": "^4.7.1",
    "react-leaflet": "^4.2.1",
    "satellite.js": "^7.0.0",
    "three": "^0.183.2",
    "zustand": "^4.3.2"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/react": "18.0.15",
    "@types/react-dom": "18.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.5.3",
    "eslint-plugin-cypress": "^4.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest-dom": "^5.0.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.32.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-storybook": "^0.11.0",
    "eslint-plugin-testing-library": "^7.0.0",
    "postcss": "^8.4.31",
    "postcss-preset-mantine": "^1.0.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.0.0",
    "sass": "^1.69.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
