# Cloudflare Worker URL — e.g. https://personal-site-api.YOUR_ACCOUNT.workers.dev
# For local dev, use: http://localhost:8787  (wrangler dev)
CF_WORKER_URL=http://localhost:8787

# The shared secret used to authenticate writes to the Worker.
# Generate with:  openssl rand -hex 32
# Then register it in CloudFlare with:  wrangler secret put API_TOKEN  (inside cloudflare-worker/)
CF_WORKER_TOKEN=123

# ── Cloudflare Access (admin authentication) ──────────────────────────────────
# Set these to enable JWT verification for admin routes in production.
# Leave blank in local dev — the app will bypass auth automatically.
#
# CF_ACCESS_TEAM_DOMAIN:  Your Zero Trust team domain.
#   Example: https://myteam.cloudflareaccess.com
#
# CF_ACCESS_AUD:  The Application Audience (AUD) tag for your Access application.
#   Found in: Cloudflare One → Access controls → Applications → your app → Basic information
#
# Setup steps:
#   1. https://one.dash.cloudflare.com → enable Zero Trust (free up to 50 users)
#   2. Create an Access application; protect paths /admin* and /api/admin/*
#   3. Choose an identity provider (GitHub recommended for a personal site)
#   4. Copy the AUD tag below and set CF_ACCESS_TEAM_DOMAIN
#   5. Add both vars to your Vercel project environment variables
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# Local dev only: set to "true" to simulate admin view, "false" (or unset) for visitor view.
# Has no effect when CF_ACCESS_AUD is set (production uses real JWT verification).
DEV_ADMIN=true

# Display name pre-filled in comment forms when logged in as admin.
ADMIN_DISPLAY_NAME=Triet Cao
